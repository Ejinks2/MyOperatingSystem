megs: 128
romimage: file=/usr/share/bochs/BIOS-bochs-latest, address=0xfffe0000
vgaromimage: file=/usr/share/bochs/VGABIOS-lgpl-latest

boot: disk
mouse: enabled=1
display_library: sdl2, options="gui_debug"
